# Deploy-time configuration for scripts/build-pages.js.
# Copy this file to `.env.deploy` (gitignored), fill in real values, then
# run `node scripts/build-pages.js` to generate dist/config.runtime.js.
#
# process.env overrides these values, so the same file can be overridden
# in CI by setting real environment variables.

# URL prefix the app is mounted under. '/geo-sonification' for placeecho.com/geo-sonification/
BASE_PATH=/geo-sonification

# Fly.io-hosted backend for /api/* + WebSocket
API_BASE=https://placeecho-geo-sonification.fly.dev
WS_URL=wss://placeecho-geo-sonification.fly.dev

# Cloudflare R2 bucket (PMTiles + ambience WAVs) behind custom domain
ASSET_BASE=https://assets.placeecho.com

# Production Mapbox public token. Must be URL-restricted to:
#   https://placeecho.com
#   http://localhost:3000
#   http://localhost:8080
MAPBOX_TOKEN=pk.REPLACE_ME
