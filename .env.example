# Geo-Sonification Server Configuration
# Copy to .env and modify as needed. All values below are defaults.
# See server/config.js for details.

# ---- Network ----
# Single port serves both HTTP and WebSocket. `PORT` takes precedence if set
# (Fly.io / most PaaS providers inject it automatically); falls back to HTTP_PORT.
HTTP_PORT=3000

# ---- Aggregation ----
USE_LEGACY_AGGREGATION=false # true = simple grid-count average; false = v2 area-weighted

# Coastal cell weighting (v2 only):
LAND_FRACTION_WEIGHT_MODE=identity   # identity | linear | sqrt | pow
LAND_FRACTION_WEIGHT_EXP=1           # exponent when mode=pow
MIN_LAND_AREA_KM2=0                  # skip cells with less land (aggregation only)

# ---- CORS ----
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Grid geometry ----
GRID_SIZE=0.5                        # Grid cell size in degrees (0.25, 0.5, 1, 2, 5). Must divide evenly into 360 and 180.

# ---- Per-grid mode ----
# Method 1: center + hysteresis half-width (simpler)
PER_GRID_THRESHOLD=50                # Center threshold for per-grid mode
PER_GRID_HYSTERESIS=0                # Half-width of dead zone (0 = no hysteresis)
# Method 2: explicit enter/exit thresholds (overrides Method 1 if set)
# PER_GRID_THRESHOLD_ENTER=150       # Enter per-grid when gridCount <= this
# PER_GRID_THRESHOLD_EXIT=180        # Exit per-grid when gridCount > this

# ---- Proximity signal ----
PROXIMITY_ZOOM_LOW=4         # zoom <= low => proximity = 0 (distant/ocean)
PROXIMITY_ZOOM_HIGH=6        # zoom >= high => proximity = 1 (zoomed in)

# ---- Cache ----
DISABLE_CACHE=false          # true = always parse CSVs, never read/write cache
FORCE_REBUILD_CACHE=false    # true = ignore existing cache, rebuild from CSVs

# ---- Broadcast ----
BROADCAST_STATS=false        # true = send viewport stats to ALL WebSocket clients
