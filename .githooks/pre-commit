#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

STAGED_FILES=()
while IFS= read -r -d '' file; do
    STAGED_FILES+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [[ "${#STAGED_FILES[@]}" -eq 0 ]]; then
    exit 0
fi

echo "pre-commit: running Prettier on staged files..."

if ! npx --no-install prettier --ignore-unknown --write "${STAGED_FILES[@]}"; then
    echo "pre-commit: Prettier failed. Fix the files and commit again." >&2
    exit 1
fi

git add -- "${STAGED_FILES[@]}"

echo "pre-commit: staged files formatted and re-staged."
