# Dependencies
node_modules/

# OS files
.DS_Store

# Logs
*.log

# Cache files (derived data, avoid cache drift across machines — rm -rf data/cache to clear all)
data/cache/

# Pre-built vector tiles (regenerate with: npm run build:tiles --prefix server)
data/tiles/

# Third-party source data (e.g. Natural Earth) — downloaded locally, not tracked
data/sources/

# Local configuration (not in repository)
.env
frontend/config.local.js

# Max/MSP artifacts
sonification/

# Audio samples (too large for git) — both source WAVs and Opus derivatives
frontend/audio/ambience/*.wav
frontend/audio/ambience/*.opus

# AI agent session/cache data (local-only)
.claude/

# CLAUDE.md and AGENTS.md are tracked as project-level agent guidance —
# personal preferences belong in the global ~/.claude/CLAUDE.md instead.

# Deploy-time secrets + build output
.env.deploy
dist/

# Vitest coverage reports (regenerate with: npm run test:frontend -- --coverage)
coverage/
