{
    "name": "geo-sonification",
    "version": "1.0.0",
    "private": true,
    "description": "Interactive map that streams geographic metrics to Max/MSP via OSC",
    "scripts": {
        "start": "npm --prefix server start",
        "dev": "npm --prefix server run dev",
        "check:csv": "node scripts/check_csv_schema.js",
        "clean:cache": "rm -rf data/cache",
        "test": "npm --prefix server test",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.3.0",
        "prettier": "^3.8.1"
    }
}
